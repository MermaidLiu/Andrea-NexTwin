.page-container {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #0B1535;
  overflow: hidden;
}

.map-area {
  flex: 1;
  position: relative;
  overflow: hidden;
  min-height: 0;
}

.venue-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding-top: env(safe-area-inset-top);
  height: calc(env(safe-area-inset-top) + 88rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 32rpx;
  padding-right: 240rpx;
  z-index: 50;
  background: linear-gradient(180deg, rgba(11, 21, 53, 0.92) 0%, transparent 100%);
  pointer-events: none;
}

.brand-block,
.top-actions {
  pointer-events: auto;
}

.top-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wishlist-entry {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(35, 89, 190, 0.15);
  border: 1rpx solid rgba(35, 89, 190, 0.3);
  border-radius: 50%;
}

.alliance-entry {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(162, 52, 213, 0.12);
  border: 1rpx solid rgba(162, 52, 213, 0.3);
  border-radius: 50%;
}

.wishlist-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  padding: 0 6rpx;
  background: #A234D5;
  border-radius: 14rpx;
  font-size: 18rpx;
  color: #fff;
  text-align: center;
  font-weight: 600;
}

.brand-block {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.app-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #F0F4FF;
  letter-spacing: 4rpx;
}

.app-year {
  font-size: 28rpx;
  font-weight: 700;
  color: #A234D5;
}

.cross-venue-btn {
  padding: 10rpx 24rpx;
  background: rgba(35, 89, 190, 0.18);
  border: 1rpx solid rgba(35, 89, 190, 0.45);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #4A7FD4;
}

.cross-venue-btn:active {
  background: rgba(162, 52, 213, 0.25);
  border-color: rgba(162, 52, 213, 0.5);
  color: #C56AE8;
}

/* Welcome overlay */
.welcome-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(11, 21, 53, 0.88);
  backdrop-filter: blur(16px);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease;
}

.welcome-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.welcome-card {
  width: 86%;
  max-width: 640rpx;
  padding: 48rpx 40rpx 40rpx;
  background: linear-gradient(160deg, #152452 0%, #101E45 100%);
  border-radius: 32rpx;
  border: 1rpx solid rgba(35, 89, 190, 0.3);
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.4);
}

.welcome-brand-line {
  width: 80rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #2359BE, #A234D5);
  border-radius: 3rpx;
  margin-bottom: 24rpx;
}

.welcome-title {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #F0F4FF;
  letter-spacing: 6rpx;
  margin-bottom: 8rpx;
}

.welcome-subtitle {
  display: block;
  font-size: 26rpx;
  color: #A234D5;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.welcome-hint {
  display: block;
  font-size: 24rpx;
  color: #6B82B0;
  margin-bottom: 36rpx;
}

.location-cards {
  margin-bottom: 32rpx;
}

.location-card {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  background: rgba(35, 89, 190, 0.08);
  border: 1rpx solid rgba(35, 89, 190, 0.2);
  border-radius: 20rpx;
  transition: background 0.2s ease;
}

.location-card:active {
  background: rgba(162, 52, 213, 0.15);
  border-color: rgba(162, 52, 213, 0.35);
}

.location-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 0 12rpx currentColor;
}

.location-info {
  flex: 1;
}

.location-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #F0F4FF;
}

.location-count {
  display: block;
  font-size: 22rpx;
  color: #6B82B0;
  margin-top: 4rpx;
}

.location-arrow {
  display: none;
}

.enter-map-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2359BE 0%, #A234D5 100%);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(35, 89, 190, 0.35);
}

.enter-map-btn text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2rpx;
  line-height: 1;
}

.alliance-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 24rpx 20rpx;
  background: rgba(162, 52, 213, 0.08);
  border: 1rpx solid rgba(162, 52, 213, 0.25);
  border-radius: 20rpx;
}

.alliance-banner-text {
  flex: 1;
}

.alliance-banner-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #C56AE8;
}

.alliance-banner-sub {
  display: block;
  font-size: 22rpx;
  color: #6B82B0;
  margin-top: 4rpx;
}

/* Bottom nav area – always visible, never covered by canvas */
.nav-area {
  flex-shrink: 0;
  position: relative;
  z-index: 200;
  background: #0B1535;
}

/* Track mode map labels */
.map-labels-layer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 60;
  overflow: hidden;
}

.zone-label {
  position: absolute;
  transform: translate(-50%, -50%);
  padding: 6rpx 16rpx;
  background: rgba(11, 21, 53, 0.75);
  border: 1rpx solid rgba(35, 89, 190, 0.4);
  border-radius: 12rpx;
  pointer-events: none;
}

.zone-label text {
  font-size: 22rpx;
  color: #4A7FD4;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.poi-label {
  position: absolute;
  transform: translate(-50%, -100%);
  margin-top: -16rpx;
  min-width: 200rpx;
  max-width: 280rpx;
  padding: 12rpx 16rpx;
  background: rgba(16, 30, 69, 0.92);
  border: 1rpx solid rgba(162, 52, 213, 0.45);
  border-radius: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.35);
  pointer-events: auto;
}

.poi-label-name {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #F0F4FF;
  line-height: 1.3;
  margin-bottom: 4rpx;
}

.poi-label-loc {
  display: block;
  font-size: 20rpx;
  color: #4A7FD4;
  margin-bottom: 4rpx;
}

.poi-label-time {
  display: block;
  font-size: 20rpx;
  color: #C56AE8;
  font-weight: 600;
}
