.wishlist-page {
  min-height: 100vh;
  background: #0B1535;
  display: flex;
  flex-direction: column;
}

.page-header {
  padding: calc(env(safe-area-inset-top) + 24rpx) 32rpx 24rpx;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.back-btn text {
  font-size: 28rpx;
  color: #4A7FD4;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #F0F4FF;
  margin-bottom: 8rpx;
}

.page-sub {
  display: block;
  font-size: 24rpx;
  color: #6B82B0;
}

.wishlist-scroll {
  flex: 1;
  height: 0;
  padding: 0 32rpx 32rpx;
}

.wishlist-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: rgba(35, 89, 190, 0.08);
  border: 1rpx solid rgba(35, 89, 190, 0.2);
  border-radius: 20rpx;
}

.item-main {
  flex: 1;
}

.item-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #F0F4FF;
  margin-bottom: 8rpx;
}

.item-venue {
  display: block;
  font-size: 24rpx;
  color: #4A7FD4;
  margin-bottom: 4rpx;
}

.item-time {
  display: block;
  font-size: 22rpx;
  color: #6B82B0;
}

.item-remove {
  padding: 16rpx;
  margin-left: 12rpx;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #9BB0D9;
  margin-top: 32rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #6B82B0;
  margin-top: 12rpx;
  text-align: center;
  line-height: 1.6;
}
