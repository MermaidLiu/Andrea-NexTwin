.detail-page {
  min-height: 100vh;
  background: #0B1535;
  display: flex;
  flex-direction: column;
}

.detail-header {
  padding-top: env(safe-area-inset-top);
  padding: calc(env(safe-area-inset-top) + 16rpx) 32rpx 16rpx;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.back-btn text {
  font-size: 28rpx;
  color: #4A7FD4;
}

.detail-scroll {
  flex: 1;
  height: 0;
}

.detail-content {
  padding: 16rpx 32rpx 200rpx;
}

.venue-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: rgba(35, 89, 190, 0.15);
  border: 1rpx solid rgba(35, 89, 190, 0.35);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #4A7FD4;
  margin-bottom: 20rpx;
}

.session-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #f1f5f9;
  line-height: 1.4;
  margin-bottom: 32rpx;
}

.info-card {
  background: rgba(255, 255, 255, 0.04);
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #64748b;
}

.info-value {
  font-size: 26rpx;
  color: #e2e8f0;
  text-align: right;
  max-width: 60%;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #94a3b8;
  margin-bottom: 16rpx;
}

.section-body {
  display: block;
  font-size: 28rpx;
  color: #cbd5e1;
  line-height: 1.7;
}

.track-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.track-tag {
  padding: 8rpx 20rpx;
  background: rgba(139, 92, 246, 0.15);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #a78bfa;
}

.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: rgba(11, 21, 53, 0.95);
  backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(35, 89, 190, 0.2);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn text {
  line-height: 1;
}

.wishlist-btn {
  background: rgba(35, 89, 190, 0.12);
  border: 1rpx solid rgba(35, 89, 190, 0.3);
  color: #4A7FD4;
}

.wishlist-btn.active {
  background: rgba(162, 52, 213, 0.15);
  border-color: rgba(162, 52, 213, 0.35);
  color: #C56AE8;
}

.remind-btn {
  background: linear-gradient(135deg, #2359BE, #A234D5);
  color: #fff;
}
