.alliance-page {
  min-height: 100vh;
  background: #0B1535;
  padding: 32rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
}

.hero-section {
  position: relative;
  text-align: center;
  padding: 48rpx 24rpx 40rpx;
  margin-bottom: 32rpx;
}

.hero-glow {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(162, 52, 213, 0.2) 0%, transparent 70%);
  pointer-events: none;
}

.hero-icon-wrap {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(35, 89, 190, 0.12);
  border: 1rpx solid rgba(162, 52, 213, 0.35);
  border-radius: 28rpx;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #F0F4FF;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.hero-tagline {
  display: block;
  font-size: 26rpx;
  color: #A234D5;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.hero-desc {
  display: block;
  font-size: 26rpx;
  color: #9BB0D9;
  line-height: 1.7;
  padding: 0 16rpx;
}

.benefits-section {
  background: rgba(16, 30, 69, 0.8);
  border: 1rpx solid rgba(35, 89, 190, 0.25);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #4A7FD4;
  margin-bottom: 24rpx;
}

.benefit-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.benefit-item:last-child {
  margin-bottom: 0;
}

.benefit-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2359BE, #A234D5);
  margin-top: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.benefit-text {
  flex: 1;
  font-size: 26rpx;
  color: #C8D6F5;
  line-height: 1.6;
}

.join-section {
  text-align: center;
}

.join-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #2359BE 0%, #A234D5 100%);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(35, 89, 190, 0.35);
}

.join-btn text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
  line-height: 1;
}

.join-hint {
  display: block;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #6B82B0;
}

.group-section {
  text-align: center;
}

.member-badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 24rpx;
  background: rgba(162, 52, 213, 0.15);
  border: 1rpx solid rgba(162, 52, 213, 0.35);
  border-radius: 24rpx;
  margin-bottom: 28rpx;
}

.member-badge text {
  font-size: 24rpx;
  color: #C56AE8;
  font-weight: 600;
}

.group-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #F0F4FF;
  margin-bottom: 8rpx;
}

.group-name {
  display: block;
  font-size: 26rpx;
  color: #4A7FD4;
  margin-bottom: 32rpx;
}

.qr-wrap {
  display: inline-block;
  padding: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.3);
  margin-bottom: 20rpx;
}

.qr-image {
  width: 400rpx;
  height: 400rpx;
  display: block;
}

.qr-hint {
  display: block;
  font-size: 24rpx;
  color: #6B82B0;
  line-height: 1.6;
  margin-bottom: 32rpx;
  padding: 0 16rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn text {
  line-height: 1;
}

.action-btn.outline {
  background: rgba(35, 89, 190, 0.1);
  border: 1rpx solid rgba(35, 89, 190, 0.35);
  color: #4A7FD4;
}

.action-btn.primary {
  background: linear-gradient(135deg, #2359BE, #A234D5);
  color: #fff;
}
