.venue-drawer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 50vh;
  background: rgba(16, 30, 69, 0.97);
  backdrop-filter: blur(24px);
  border-radius: 32rpx 32rpx 0 0;
  border-top: 1rpx solid rgba(35, 89, 190, 0.35);
  z-index: 160;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
}

.drawer-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 150;
  pointer-events: none;
  transition: background 0.3s ease;
}

.drawer-mask.show {
  background: rgba(0, 0, 0, 0.4);
  pointer-events: auto;
}

.venue-drawer.show {
  transform: translateY(0);
}

.drawer-handle {
  width: 64rpx;
  height: 6rpx;
  background: rgba(35, 89, 190, 0.4);
  border-radius: 3rpx;
  margin: 16rpx auto 8rpx;
}

.session-swiper {
  flex: 1;
  height: 0;
}

.drawer-content {
  height: 100%;
  padding: 16rpx 32rpx 24rpx;
}

.venue-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  background: rgba(35, 89, 190, 0.15);
  border: 1rpx solid rgba(35, 89, 190, 0.35);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #4A7FD4;
  margin-bottom: 16rpx;
}

.session-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #F0F4FF;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.session-desc {
  display: block;
  font-size: 26rpx;
  color: #9BB0D9;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(35, 89, 190, 0.12);
}

.meta-label {
  font-size: 24rpx;
  color: #6B82B0;
}

.meta-value {
  font-size: 24rpx;
  color: #C8D6F5;
}

.track-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.track-tag {
  padding: 6rpx 16rpx;
  background: rgba(162, 52, 213, 0.15);
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #C56AE8;
}

.swipe-hint {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 32rpx 16rpx;
  font-size: 22rpx;
  color: #6B82B0;
}

.page-indicator {
  color: #4A7FD4;
  font-weight: 600;
}

.wishlist-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 28rpx;
  padding: 20rpx;
  background: rgba(35, 89, 190, 0.1);
  border: 1rpx solid rgba(35, 89, 190, 0.25);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #4A7FD4;
}

.wishlist-btn.active {
  background: rgba(162, 52, 213, 0.12);
  border-color: rgba(162, 52, 213, 0.35);
  color: #C56AE8;
}
