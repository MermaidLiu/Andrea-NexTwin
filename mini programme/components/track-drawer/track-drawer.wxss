.track-drawer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(16, 30, 69, 0.96);
  backdrop-filter: blur(24px);
  border-radius: 32rpx 32rpx 0 0;
  border-top: 1rpx solid rgba(162, 52, 213, 0.3);
  z-index: 140;
  transition: height 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.track-drawer.collapsed {
  height: 100rpx;
}

.track-drawer.expanded {
  height: 45vh;
}

.track-drawer.expanded.has-sessions {
  height: 58vh;
}

.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  height: 100rpx;
  flex-shrink: 0;
}

.header-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.header-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #F0F4FF;
}

.header-sub {
  font-size: 22rpx;
  color: #C56AE8;
  margin-top: 4rpx;
}

.drawer-body {
  flex: 1;
  height: 0;
}

.track-chips-scroll {
  white-space: nowrap;
  padding: 0 24rpx 16rpx;
}

.track-chips {
  display: inline-flex;
  gap: 12rpx;
}

.track-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: rgba(35, 89, 190, 0.06);
  border: 2rpx solid rgba(35, 89, 190, 0.15);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.track-chip.active {
  background: rgba(35, 89, 190, 0.18);
  border-color: #2359BE;
}

.track-chip text {
  font-size: 24rpx;
  color: #9BB0D9;
}

.track-chip.active text {
  color: #4A7FD4;
  font-weight: 600;
}

.sessions-section {
  padding: 0 24rpx 24rpx;
}

.sessions-hint {
  display: block;
  font-size: 22rpx;
  color: #6B82B0;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.session-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: rgba(35, 89, 190, 0.08);
  border: 1rpx solid rgba(35, 89, 190, 0.2);
  border-radius: 20rpx;
  transition: background 0.2s ease;
}

.session-card:active {
  background: rgba(162, 52, 213, 0.12);
  border-color: rgba(162, 52, 213, 0.3);
}

.session-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.session-card-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #F0F4FF;
  line-height: 1.4;
}

.session-card-time {
  font-size: 22rpx;
  color: #A234D5;
  font-weight: 600;
  white-space: nowrap;
  flex-shrink: 0;
}

.session-card-venue,
.session-card-location {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 8rpx;
}

.session-card-venue text,
.session-card-location text {
  font-size: 24rpx;
  color: #9BB0D9;
  line-height: 1.4;
}

.no-sessions,
.pick-track-hint {
  padding: 32rpx 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: #6B82B0;
}
