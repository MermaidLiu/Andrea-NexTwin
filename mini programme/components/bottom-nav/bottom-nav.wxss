.bottom-nav {
  display: flex;
  height: 110rpx;
  background: #101E45;
  border-top: 1rpx solid rgba(35, 89, 190, 0.35);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.25);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
  opacity: 0.45;
}

.nav-item.active {
  opacity: 1;
}

.nav-item.active .nav-icon-wrap {
  background: rgba(35, 89, 190, 0.2);
}

.nav-item.active .nav-label {
  color: #4A7FD4;
}

.nav-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
  transition: background 0.25s ease;
}

.nav-icon {
  font-size: 32rpx;
}

.nav-label {
  font-size: 22rpx;
  color: #6B82B0;
  font-weight: 500;
  transition: color 0.25s ease;
}

.nav-item.active .nav-label {
  font-weight: 600;
}
