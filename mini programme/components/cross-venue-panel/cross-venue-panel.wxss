.cross-venue-panel {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 100rpx);
  left: 24rpx;
  right: 24rpx;
  background: rgba(16, 30, 69, 0.96);
  backdrop-filter: blur(24px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(35, 89, 190, 0.35);
  z-index: 180;
  padding: 24rpx;
  transform: translateY(-120%);
  opacity: 0;
  transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  max-height: 60vh;
  overflow-y: auto;
}

.cross-venue-panel.show {
  transform: translateY(0);
  opacity: 1;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #4A7FD4;
}

.panel-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.selector-section {
  margin-bottom: 20rpx;
}

.selector-label {
  display: block;
  font-size: 24rpx;
  color: #9BB0D9;
  margin-bottom: 12rpx;
}

.venue-scroll {
  white-space: nowrap;
}

.venue-chip {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  background: rgba(35, 89, 190, 0.08);
  border: 1rpx solid rgba(35, 89, 190, 0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #9BB0D9;
  transition: all 0.2s ease;
}

.venue-chip.selected {
  background: rgba(162, 52, 213, 0.15);
  border-color: #A234D5;
  color: #C56AE8;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-calculate {
  flex: 1;
  background: linear-gradient(135deg, #2359BE, #A234D5);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  border-radius: 16rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.btn-calculate[disabled] {
  opacity: 0.4;
}

.btn-clear {
  background: rgba(35, 89, 190, 0.1);
  color: #9BB0D9;
  font-size: 26rpx;
  border: none;
  border-radius: 16rpx;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 32rpx;
}

.route-result {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(35, 89, 190, 0.15);
}

.route-summary {
  margin-bottom: 16rpx;
}

.route-time {
  font-size: 28rpx;
  font-weight: 700;
  color: #C56AE8;
}

.route-steps {
  padding-left: 8rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.step-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2359BE;
  margin-top: 10rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
}

.step-text {
  display: block;
  font-size: 26rpx;
  color: #F0F4FF;
  line-height: 1.5;
}

.step-duration {
  display: block;
  font-size: 22rpx;
  color: #6B82B0;
  margin-top: 4rpx;
}
