# G1 真机 + YOLO 环境变量
UNITREE_ROBOT_MODEL=g1
UNITREE_SENSOR_MODE=ros2
UNITREE_LIDAR_TOPIC=/utlidar/cloud
UNITREE_CAMERA_TOPIC=/camera/color/image_raw
UNITREE_DEPTH_TOPIC=/camera/depth/image_rect_raw
UNITREE_IMU_TOPIC=/utlidar/imu
UNITREE_CONTROL_MODE=mock

# YOLO — 对 G1 相机四向切分帧做检测
NEXTWIN_ENABLE_YOLO=1
YOLO_MODEL=yolov8n.pt
# 自训练救援模型（mini_pi / heavy_debris）放到 models/ 后改为：
# YOLO_MODEL=rescue_yolo.pt
YOLO_CONF=0.25
YOLO_DEVICE=cpu
